# ============================================================
# 舞拍 DancePulse · 环境变量模板
# 复制为 .env 后填写
# ============================================================

# ---------- VLM (千问视觉 / 阿里云百炼) ----------
# 官方兼容模式文档：
# https://help.aliyun.com/zh/model-studio/developer-reference/qwen-vl-compatible-with-openai
DASHSCOPE_API_KEY=
DASHSCOPE_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
QWEN_MODEL=qwen-vl-plus
# mock | real；留空时：有 key 自动 real，没有 key 自动 mock
DP_VLM_MODE=

# ---------- Mock 开关 ----------
# true 时 teaching 模块返回固定假数据，不调真 VLM
USE_MOCK_TEACHING=false
# true 时 backend 的 PATCH segments 不真切 MP4，只 sleep 模拟
USE_MOCK_CLIP_REEXPORT=false

# ---------- 抖音链接导入 ----------
# 可选：指定 cookies 文件（Netscape 格式），优先级高于浏览器 cookies
DOUYIN_COOKIES_FILE=
# 可选：指定浏览器 cookies 来源，支持逗号分隔多个来源
# 例：edge:Default,chrome:Default,safari
# 留空时会按系统自动探测可用浏览器
DOUYIN_COOKIES_FROM_BROWSER=
# 默认 true：抖音下载时主动绕过终端代理，减少 cookies / IP 不一致导致的验证
DOUYIN_DISABLE_PROXY=true
# 默认 true：如果抖音触发验证码，自动在本机浏览器打开链接并在后台重试
DOUYIN_AUTO_BROWSER_VERIFY=true
# 浏览器验证自动重试时长（秒）
DOUYIN_BROWSER_VERIFY_TIMEOUT=90

# ---------- 后端 ----------
API_PORT=8000
BACKEND_DATA_DIR=./backend/data
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3002,http://127.0.0.1:3002,http://localhost:3004,http://127.0.0.1:3004

# ---------- 前端 ----------
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000
# true 时前端不调后端，用 lib/mock.ts 的假数据
NEXT_PUBLIC_USE_MOCK=false

# ---------- Pipeline ----------
# MediaPipe 抽帧率（帧/秒）
PIPELINE_POSE_FPS=10
# beat 吸附容差（秒）
BEAT_TOLERANCE=0.1
# 切片粒度（拍数）
SEGMENT_GRANULARITY=8
